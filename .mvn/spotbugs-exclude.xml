<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter.

  Keep this file minimal: every exclusion must have a comment explaining why the
  finding is a false positive or an accepted risk.
-->
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

  <!-- Spring configuration properties records: constructor parameters are bound by
       Spring and intentionally exposed via record accessors. -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
    <Class name="~com\.patbaumgartner\.contactscleaner\..*Properties.*" />
  </Match>

  <!-- CRLF injection in logs: all logged values originate from configuration or the
       Google CardDAV API response of the authenticated user, not from untrusted input. -->
  <Match>
    <Bug pattern="CRLF_INJECTION_LOGS" />
  </Match>

  <!-- Locale.ROOT case-folding here builds internal comparison keys for duplicate
       detection (report-only); no security decision is derived from the transformed
       string, so Unicode case-mapping quirks are harmless. -->
  <Match>
    <Bug pattern="IMPROPER_UNICODE" />
    <Class name="~com\.patbaumgartner\.contactscleaner\.cleaning\.(DuplicateContactDetector|FlippedNameRepairRule|CustomFieldRemovalRule|OrganizationRemovalRule|RedundantAddressRemovalRule|FaxNumberRemovalRule|LabelNormalizationRule)" />
  </Match>

  <!-- FindSecBugs' ReDoS detector does not model possessive quantifiers (++): the
       e-mail regex uses them exclusively, which makes backtracking impossible and the
       match linear. Additionally, inputs are the user's own vCard field values, not
       attacker-controlled payloads. -->
  <Match>
    <Bug pattern="REDOS" />
    <Class name="com.patbaumgartner.contactscleaner.cleaning.InvalidEmailRemovalRule" />
  </Match>

  <!-- HtmlReportWriter escapes every dynamic value via its escape() method before
       appending; FindSecBugs cannot trace the sanitizer through method calls and
       flags each append as potential XML injection. The report is also a local file
       rendered from the user's own contact data, not a served web page. -->
  <Match>
    <Bug pattern="POTENTIAL_XML_INJECTION" />
    <Class name="com.patbaumgartner.contactscleaner.reporting.HtmlReportWriter" />
  </Match>

  <!-- GoogleCardDavClient.multiget() escapes each href via escapeXml() before
       appending; FindSecBugs cannot trace the sanitizer. The hrefs also originate
       from the server's own PROPFIND response, not from untrusted input. -->
  <Match>
    <Bug pattern="POTENTIAL_XML_INJECTION" />
    <Class name="com.patbaumgartner.contactscleaner.carddav.GoogleCardDavClient" />
  </Match>

</FindBugsFilter>
