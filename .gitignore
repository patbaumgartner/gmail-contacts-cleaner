##############################################################################
# Gmail Contacts Cleaner – .gitignore
##############################################################################

# ── Secrets — never commit ────────────────────────────────────────────────────
.env
*.env.local

# ── Java / Maven (contacts-cleaner/) ──────────────────────────────────────────
contacts-cleaner/target/
contacts-cleaner/pom.xml.bak
contacts-cleaner/pom.xml.versionBackup
HELP.md

# Maven wrapper binary (downloaded on demand, not committed)
contacts-cleaner/.mvn/wrapper/maven-wrapper.jar

# IDE project files
.idea/
*.iws
*.iml
*.ipr
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
.apt_generated/

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# VS Code
.vscode/

# Build outputs inside src (Maven test-filtered resources)
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
