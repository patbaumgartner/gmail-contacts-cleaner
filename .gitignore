##############################################################################
# Gmail Contacts Cleaner – .gitignore
##############################################################################

# ── Secrets — never commit ────────────────────────────────────────────────────
.env
*.env.local

# ── Java / Maven ──────────────────────────────────────────────────────────────
target/
pom.xml.bak
pom.xml.versionBackup
HELP.md

# Maven wrapper binary (downloaded on demand, not committed)
.mvn/wrapper/maven-wrapper.jar

# IDE project files
.idea/
*.iws
*.iml
*.ipr
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
.apt_generated/

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# VS Code
.vscode/*
!.vscode/settings.json

# Build outputs inside src (Maven test-filtered resources)
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log

# ── Local test data — real contact exports contain personal data, never commit ─
# (only the README describing the setup is tracked)
test-data/*
!test-data/README.md

# ── Generated cleanup reports (contain personal contact data) ─────────────────
reports/
