# ─────────────────────────────────────────────────────────────────────────────
# Gmail Contacts Cleaner – environment configuration template
#
# Copy this file to .env and fill in your accounts:
#   cp .env.example .env
#
# NEVER commit .env to source control — it is listed in .gitignore.
#
# App passwords: https://myaccount.google.com/apppasswords
# (requires 2-step verification; never use your real account password)
# ─────────────────────────────────────────────────────────────────────────────

# ── Account 0 (required) ──────────────────────────────────────────────────────
contacts-cleaner.accounts[0].name=personal
contacts-cleaner.accounts[0].email=your-email@gmail.com
contacts-cleaner.accounts[0].app-password=abcd efgh ijkl mnop
contacts-cleaner.accounts[0].enabled=true
# Strongly recommended for the first run — computes and logs all changes
# without writing anything back to Google:
contacts-cleaner.accounts[0].dry-run=true

# ── Account 1 (optional — add accounts[2], accounts[3], ... the same way) ──────
# contacts-cleaner.accounts[1].name=work
# contacts-cleaner.accounts[1].email=you@yourdomain.com
# contacts-cleaner.accounts[1].app-password=qrst uvwx yzab cdef
# contacts-cleaner.accounts[1].enabled=true
# contacts-cleaner.accounts[1].dry-run=true

# ── Runtime mode ───────────────────────────────────────────────────────────────
# Empty (default): one-shot run at startup, then exit — pair with host cron.
# 'server': long-running container with the built-in nightly scheduler.
# SPRING_PROFILES_ACTIVE=server

# ── Scheduler (server mode only) ───────────────────────────────────────────────
# CONTACTS_CLEANER_SCHEDULER_CRON=0 0 3 * * *
# CONTACTS_CLEANER_SCHEDULER_ZONE=Europe/Zurich

# ── Cleaning rules ─────────────────────────────────────────────────────────────
# Recommended: set your country so national numbers are formatted to E.164
# ("044 668 18 00" → "+41446681800"). ISO 3166-1 alpha-2 (CH, DE, US, ...).
CONTACTS_CLEANER_PHONE_REGION=CH

# Non-destructive normalization is on by default:
# CONTACTS_CLEANER_NORMALIZE_PHONE_NUMBERS=true
# CONTACTS_CLEANER_REMOVE_DUPLICATE_PHONE_NUMBERS=true
# CONTACTS_CLEANER_NORMALIZE_EMAIL_ADDRESSES=true
# CONTACTS_CLEANER_REMOVE_DUPLICATE_EMAIL_ADDRESSES=true
# CONTACTS_CLEANER_TRIM_NAMES=true
# CONTACTS_CLEANER_REMOVE_EMPTY_PROPERTIES=true
#
# Report-only duplicate contact detection (logs pairs, never merges):
# CONTACTS_CLEANER_DETECT_DUPLICATE_CONTACTS=true
#
# Promote birthdays found in notes ("Geburtstag: 12.03.1980") to a proper BDAY:
# CONTACTS_CLEANER_EXTRACT_BIRTHDAYS=true
#
# Strip XING/LinkedIn sync debris from notes (user text is preserved):
# CONTACTS_CLEANER_REMOVE_SOCIAL_NETWORK_NOTES=true
#
# Remove syntactically broken e-mail addresses (missing @, no domain):
# CONTACTS_CLEANER_REMOVE_INVALID_EMAILS=true
#
# Destructive rules are opt-in:
#
# Remove numbers invalid for their country (too short, undialable fragments);
# requires CONTACTS_CLEANER_PHONE_REGION for national numbers:
# CONTACTS_CLEANER_REMOVE_INVALID_PHONE_NUMBERS=false
#
# Auto-merge provable duplicates (same name tokens + shared phone/e-mail),
# e.g. 'Max Muster' + 'Muster Max' sharing a mobile number become one card:
# CONTACTS_CLEANER_MERGE_DUPLICATE_CONTACTS=false
#
# DNS-verify mail domains and drop addresses whose domain no longer exists:
# CONTACTS_CLEANER_VERIFY_EMAIL_DOMAINS=false
#
# Remove numbers appearing on 2+ contacts — switchboards and shared landlines;
# only direct numbers survive (raise the threshold to 3 to keep couples' landlines):
# CONTACTS_CLEANER_REMOVE_SHARED_PHONE_NUMBERS=false
# CONTACTS_CLEANER_SHARED_PHONE_NUMBER_THRESHOLD=2
#
# CONTACTS_CLEANER_REMOVE_NOTES=false
#
# Delete contacts with no phone, e-mail, birthday, address, URL, note or org:
# CONTACTS_CLEANER_DELETE_EMPTY_CONTACTS=false

# ── HTML report ────────────────────────────────────────────────────────────────
# A single-page report (reports/cleanup-report-latest.html) is written after
# every run — perfect for reviewing a dry run before going live.
# CONTACTS_CLEANER_REPORT_ENABLED=true
# CONTACTS_CLEANER_REPORT_DIRECTORY=reports

# ── Docker image version (optional) ────────────────────────────────────────────
# Leave empty or 'latest' for the most recent stable release.
# VERSION=latest
